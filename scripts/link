#!/usr/bin/env bash
# Link generated skill directories into each agent's local skill directory.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_NAME="readable-html"

usage() {
  cat >&2 <<'USAGE'
Usage: scripts/link <link|unlink> <agent|all>

Examples:
  scripts/link link codex
  scripts/link link claude-code
  scripts/link unlink all
USAGE
}

destination_for() {
  case "$1" in
    claude-code)
      printf '%s/.claude/skills/%s\n' "${HOME}" "${SKILL_NAME}"
      ;;
    codex)
      printf '%s/.codex/skills/%s\n' "${HOME}" "${SKILL_NAME}"
      ;;
    *)
      echo "ERROR: unsupported agent: $1" >&2
      exit 1
      ;;
  esac
}

link_one() {
  local agent="$1"
  local source="${ROOT_DIR}/agents/${agent}/${SKILL_NAME}"
  local dest
  dest="$(destination_for "${agent}")"

  if [[ ! -d "${source}" ]]; then
    echo "ERROR: build output missing: ${source#${ROOT_DIR}/}" >&2
    echo "Run scripts/build agents ${agent} first." >&2
    exit 1
  fi

  mkdir -p "$(dirname "${dest}")"
  if [[ -L "${dest}" ]]; then
    local current
    current="$(readlink "${dest}")"
    if [[ "${current}" == "${source}" ]]; then
      echo "Skip link (already correct): ${dest}"
      return 0
    fi
    echo "ERROR: existing symlink points elsewhere: ${dest} -> ${current}" >&2
    exit 1
  fi
  if [[ -e "${dest}" ]]; then
    echo "ERROR: destination exists and is not a symlink: ${dest}" >&2
    exit 1
  fi

  ln -s "${source}" "${dest}"
  echo "Linked ${dest} -> ${source}"
}

unlink_one() {
  local agent="$1"
  local dest
  dest="$(destination_for "${agent}")"

  if [[ -L "${dest}" ]]; then
    rm "${dest}"
    echo "Unlinked ${dest}"
  elif [[ -e "${dest}" ]]; then
    echo "ERROR: destination exists and is not a symlink: ${dest}" >&2
    exit 1
  else
    echo "Skip unlink (missing): ${dest}"
  fi
}

if [[ $# -ne 2 ]]; then
  usage
  exit 1
fi

command="$1"
agent_arg="$2"

case "${command}" in
  link|unlink) ;;
  *)
    echo "ERROR: unknown command: ${command}" >&2
    usage
    exit 1
    ;;
esac

agents=()
if [[ "${agent_arg}" == "all" ]]; then
  agents=(claude-code codex)
else
  agents=("${agent_arg}")
fi

for agent in "${agents[@]}"; do
  case "${command}" in
    link) link_one "${agent}" ;;
    unlink) unlink_one "${agent}" ;;
  esac
done
