#!/usr/bin/env bash
# Create package archives from generated dist skill directories.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_NAME="readable-html"

usage() {
  cat >&2 <<'USAGE'
Usage: scripts/package [agent|all]

Examples:
  scripts/package
  scripts/package codex
USAGE
}

require_cmd() {
  local cmd="$1"
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "ERROR: ${cmd} is required" >&2
    exit 1
  fi
}

package_one() {
  local agent="$1"
  local source="${ROOT_DIR}/agents/${agent}/${SKILL_NAME}"
  local archive="${ROOT_DIR}/dist/${agent}/${SKILL_NAME}.zip"

  if [[ ! -d "${source}" ]]; then
    echo "ERROR: package source missing: ${source#${ROOT_DIR}/}" >&2
    echo "Run scripts/build ${agent} first." >&2
    exit 1
  fi

  mkdir -p "$(dirname "${archive}")"
  rm -f "${archive}"
  (
    cd "${ROOT_DIR}/agents/${agent}"
    zip -qr "${archive}" "${SKILL_NAME}"
  )
  echo "Packaged ${archive#${ROOT_DIR}/}"
}

agent_arg="${1:-all}"

case "${agent_arg}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

require_cmd zip

agents=()
if [[ "${agent_arg}" == "all" ]]; then
  while IFS= read -r dir; do
    agents+=("$(basename "${dir}")")
  done < <(find "${ROOT_DIR}/src/agents" -mindepth 1 -maxdepth 1 -type d | sort)
else
  agents=("${agent_arg}")
fi

if [[ ${#agents[@]} -eq 0 ]]; then
  echo "ERROR: no agents found under src/agents" >&2
  exit 1
fi

for agent in "${agents[@]}"; do
  package_one "${agent}"
done
